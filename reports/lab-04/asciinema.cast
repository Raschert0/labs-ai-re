[0.001, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"capabilities\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m{}\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"defaultInputModes\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n    \u001b[0;32m\"text/plain\"\u001b[0m\u001b[1;39m\r\n  \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"defaultOutputModes\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n    \u001b[0;32m\"text/plain\"\u001b[0m\u001b[1;39m\r\n"]
[0.000, "o", "  \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"AI infrastructure advisor for the k8s lab cluster. Provides information about deployed AI components, agents, and MCP endpoints.\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"ai_infra_advisor\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"preferredTransport\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"JSONRPC\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"protocolVersion\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"0.3.0\"\u001b[0m\u001b[1;39m,\r\n"]
[0.000, "o", "  \u001b[0m\u001b[1;34m\"skills\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n    \u001b[1;39m{\r\n      \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"AI infrastructure advisor for the k8s lab cluster. Provides information about deployed AI components, agents, and MCP endpoints. I am an AI infrastructure advisor for a Kubernetes lab cluster running in a Codespace. I have knowledge about the AI components running in the cluster: kagent agents, agentgateway backends, and MCP servers. Help users understand the AI infrastructure topology, available agents, and how to interact with them. Use my tools to retrieve current infrastructure state before answering.\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"examples\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[]\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"ai_infra_advisor\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"model\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"tags\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n        \u001b[0;32m\"llm\"\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n    \u001b[1;39m{\r\n      \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Returns a description of AI infrastructure components running in the cluster.\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"ai_infra_advisor-describe_infrastructure\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"describe_infrastructure\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"tags\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n        \u001b[0;32m\"llm\"\u001b[0m\u001b[1;39m,\r\n        \u001b[0;32m\"tools\"\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n    \u001b[1;39m{\r\n      \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Lists all AI agents deployed in the cluster with their capabilities.\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"ai_infra_advisor-list_ai_agents\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"list_ai_agents\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"tags\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n        \u001b[0;32m\"llm\"\u001b[0m\u001b[1;39m,\r\n        \u001b[0;32m\"tools\"\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m,\r\n    \u001b[1;39m{\r\n      \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Returns MCP server endpoints exposed in the cluster via agentgateway.\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"id\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"ai_infra_advisor-get_mcp_endpoints\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"name\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"get_mcp_endpoints\"\u001b[0m\u001b[1;39m,\r\n      \u001b[0m\u001b[1;34m\"tags\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[1;39m[\r\n        \u001b[0;32m\"llm\"\u001b[0m\u001b[1;39m,\r\n        \u001b[0;32m\"tools\"\u001b[0m\u001b[1;39m\r\n      \u001b[1;39m]\u001b[0m\u001b[1;39m\r\n    \u001b[1;39m}\u001b[0m\u001b[1;39m\r\n  \u001b[1;39m]\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"supportsAuthenticatedExtendedCard\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39mfalse\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"url\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"http://172.18.0.5/ai-infra-advisor\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"version\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"0.0.1\"\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
