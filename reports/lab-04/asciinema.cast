[1.009, "o", "\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\u001b[A\r\u001b[0;32m@Raschert0 \u001b[0m➜ \u001b[1;34m/workspaces/labs-ai-re \u001b[0;36m(\u001b[1;31mmain\u001b[0;36m) \u001b[0m$ curl -X POST http://$INGRESS_GW_ADDRESS/ai-infra-advisor   -H \"Content-Type: application/json\"   -d '{\r\n\r    \"jsonrpc\": \"2.0\",\r\n\r    \"id\": \"1\",\r\n\r    \"method\": \"message/send\",\r\n\r    \"params\": {\r\n"]
